{
    "version": 2,
    "builds": [
      {
        "src": "app.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/api/v1/appointment",
        "dest": "/routes/appointment.js"
      },
      {
        "src": "/api/v1/auth",
        "dest": "/routes/auth.js"
      },
      {
        "src": "/api/v1/portfolio",
        "dest": "/routes/portfolio.js"
      },
      {
        "src": "/api/v1/product",
        "dest": "/routes/product.js"
      },
      {
        "src": "/api/v1/tatto",
        "dest": "/routes/tatto.js"
      }
    ]
  }
